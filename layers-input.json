{
    "catalog": "https://s3-west.nrp-nautilus.io/public-data/stac/catalog.json",
    "titiler_url": "https://titiler.nrp-nautilus.io",
    "mcp_url": "https://dev-duckdb-mcp.nrp-nautilus.io/mcp",
    "auto_approve": true,
    "sidebar": {
        "enabled": true
    },
    "view": {
        "center": [
            0,
            10
        ],
        "zoom": 2
    },
    "llm": {
        "user_provided": true,
        "transcription_model": { "value": "gemma" },
        "default_endpoint": "https://openrouter.ai/api/v1",
        "models": [
            {
                "value": "anthropic/claude-sonnet-4",
                "label": "Claude Sonnet"
            },
            {
                "value": "qwen/qwen3-235b-a22b",
                "label": "Qwen3 235B"
            },
            {
                "value": "moonshotai/kimi-k2",
                "label": "Kimi K2"
            },
            {
                "value": "google/gemini-2.5-flash",
                "label": "Gemini Flash"
            }
        ]
    },
    "welcome": {
        "message": "Hi! I can help you explore the spatial and social context of the Kunming-Montreal 30×30 target (Target 3 of the Global Biodiversity Framework). Try asking:",
        "examples": [
            "What percentage of global land is currently inside a designated protected area?",
            "How many people live inside existing protected areas?",
            "Show me protected areas in the Amazon and overlay Indigenous and community lands.",
            "Which ecoregions are least represented in the current protected-area network?",
            "Show me species richness for mammals and identify the top 5 protected areas by mean richness."
        ]
    },
    "links": {
        "github": "https://github.com/boettiger-lab/global-30x30",
        "docs": "https://boettiger-lab.github.io/geo-agent/"
    },
    "collections": [
        {
            "collection_id": "wdpa-december-2025",
            "assets": [
                {
                    "id": "wdpa-pmtiles",
                    "display_name": "Protected Areas (WDPA)",
                    "group": "Protected & Conserved Areas",
                    "visible": true,
                    "default_style": {
                        "fill-color": [
                            "match",
                            ["get", "IUCN_CAT"],
                            ["Ia", "Ib", "II"], "#1b5e20",
                            ["III", "IV"], "#43a047",
                            ["V", "VI"], "#a5d6a7",
                            "#bdbdbd"
                        ],
                        "fill-opacity": 0.55
                    },
                    "outline_style": {
                        "line-color": "#1b5e20",
                        "line-width": 0.4,
                        "line-opacity": 0.7
                    },
                    "tooltip_fields": [
                        "NAME_ENG",
                        "DESIG_ENG",
                        "IUCN_CAT",
                        "STATUS",
                        "ISO3",
                        "GIS_AREA"
                    ]
                }
            ]
        },
        {
            "collection_id": "landmark-iplc-poly",
            "assets": [
                {
                    "id": "iplc-poly-pmtiles",
                    "display_name": "Indigenous & Community Lands (LandMark)",
                    "group": "Indigenous & Community Lands",
                    "visible": false,
                    "default_style": {
                        "fill-color": "#ef6c00",
                        "fill-opacity": 0.35
                    },
                    "outline_style": {
                        "line-color": "#ef6c00",
                        "line-width": 0.4,
                        "line-opacity": 0.7
                    },
                    "tooltip_fields": [
                        "name",
                        "identity",
                        "country",
                        "category",
                        "form_rec"
                    ]
                }
            ]
        },
        {
            "collection_id": "wwf-ecoregions-2017",
            "assets": [
                {
                    "id": "ecoregion-pmtiles",
                    "display_name": "Terrestrial Ecoregions (WWF)",
                    "group": "Biodiversity Context",
                    "visible": false,
                    "default_style": {
                        "fill-color": [
                            "match",
                            ["get", "NNH_NAME"],
                            "Half Protected", "#2e7d32",
                            "Nature Could Reach Half Protected", "#9ccc65",
                            "Nature Could Recover", "#fdd835",
                            "Nature Imperiled", "#e53935",
                            "#bdbdbd"
                        ],
                        "fill-opacity": 0.4
                    },
                    "outline_style": {
                        "line-color": "#424242",
                        "line-width": 0.3,
                        "line-opacity": 0.5
                    },
                    "tooltip_fields": [
                        "ECO_NAME",
                        "BIOME_NAME",
                        "REALM",
                        "NNH_NAME"
                    ]
                }
            ]
        },
        {
            "collection_id": "iucn-richness-2025",
            "assets": [
                {
                    "id": "combined-sr-cog",
                    "display_name": "Species Richness (IUCN, all vertebrates)",
                    "group": "Biodiversity Context",
                    "visible": false,
                    "colormap": "viridis",
                    "rescale": "0,1500",
                    "nodata": 0,
                    "legend_label": "species per cell"
                },
                {
                    "id": "mammals-sr-cog",
                    "display_name": "Mammal Species Richness (IUCN)",
                    "group": "Biodiversity Context",
                    "visible": false,
                    "colormap": "viridis",
                    "rescale": "0,200",
                    "nodata": 0,
                    "legend_label": "mammal species per cell"
                }
            ]
        },
        {
            "collection_id": "ncp-biodiversity",
            "assets": [
                {
                    "id": "ncp-biod-nathab-cog",
                    "display_name": "NCP — Biodiversity & Natural Habitat (Chaplin-Kramer 2019)",
                    "group": "Nature's Contributions to People",
                    "visible": false,
                    "colormap": "greens",
                    "rescale": "0,1",
                    "legend_label": "composite index"
                }
            ]
        },
        {
            "collection_id": "irrecoverable-carbon",
            "assets": [
                {
                    "id": "v2-vulnerable-2024-cog",
                    "display_name": "Vulnerable Ecosystem Carbon (2024)",
                    "group": "Nature's Contributions to People",
                    "visible": false,
                    "colormap": "ylorbr",
                    "rescale": "0,300",
                    "legend_label": "Mg C / ha"
                },
                {
                    "id": "v2-irrecoverable-2024-cog",
                    "display_name": "Irrecoverable Carbon (2024)",
                    "group": "Nature's Contributions to People",
                    "visible": false,
                    "colormap": "reds",
                    "rescale": "0,150",
                    "legend_label": "Mg C / ha"
                }
            ]
        },
        {
            "collection_id": "ghs-pop-2020",
            "collection_url": "https://s3-west.nrp-nautilus.io/public-high-seas/ghs-pop-2020/stac-collection.json",
            "assets": [
                {
                    "id": "ghs-pop-2020-cog",
                    "display_name": "Population Density (GHS-POP 2020)",
                    "group": "Population",
                    "visible": false,
                    "colormap": "magma",
                    "rescale": "0,200",
                    "nodata": 0,
                    "legend_label": "people per 90m cell"
                }
            ]
        },
        {
            "collection_id": "overture-divisions-countries-2026-02-18",
            "collection_url": "https://s3-west.nrp-nautilus.io/public-overturemaps/2026-02-18.0/countries/stac-collection.json",
            "group": { "name": "Administrative Boundaries", "collapsed": true },
            "assets": [
                {
                    "id": "countries-pmtiles",
                    "display_name": "Countries",
                    "visible": false,
                    "default_style": {
                        "fill-color": "#6A1B9A",
                        "fill-opacity": 0.03
                    },
                    "outline_style": {
                        "line-color": "#6A1B9A",
                        "line-width": 1.2,
                        "line-opacity": 0.7
                    }
                }
            ]
        },
        {
            "collection_id": "overture-divisions-regions-2026-02-18",
            "collection_url": "https://s3-west.nrp-nautilus.io/public-overturemaps/2026-02-18.0/regions/stac-collection.json",
            "group": { "name": "Administrative Boundaries", "collapsed": true },
            "assets": [
                {
                    "id": "regions-pmtiles",
                    "display_name": "Regions / States",
                    "visible": false,
                    "default_style": {
                        "fill-color": "#6A1B9A",
                        "fill-opacity": 0.03
                    },
                    "outline_style": {
                        "line-color": "#6A1B9A",
                        "line-width": 0.8,
                        "line-opacity": 0.6
                    }
                }
            ]
        }
    ]
}
